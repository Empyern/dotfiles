sort=-time
layer=overlay
width=300
height=110
border-size=0
border-radius=9
icons=1
max-icon-size=64
default-timeout=3000
ignore-timeout=1
# font=Inter Display
font=HarmonyOS Sans SC

background-color=#000000
text-color=#f9f6ef
progress-color=over #ccd0da
[urgency=low]
border-color=#000000

[urgency=normal]
border-color=#000000

[urgency=high]
border-color=#fe640b
default-timeout=0

[category=mpd]
default-timeout=2000
group-by=category

[mode=do-not-disturb]
invisible=1
